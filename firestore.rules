rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    function hasAdminProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        );
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && (
        hasAdminProfile() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function adminProtectedKeys() {
      return ['admin', 'isAdmin', 'role', 'roles', 'adminRole', 'adminPermissions', 'adminStatus'];
    }
    
    // Users collection - read own profile, admins can read all
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        !request.resource.data.keys().hasAny(adminProtectedKeys());
      allow update: if isAdmin() ||
        (
          isSignedIn() &&
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(adminProtectedKeys())
        );
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Admin collection - only admins can access
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
    
    // Songs - public read, admin write
    match /songs/{songId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Albums - public read, admin write
    match /albums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Playlists - public read, owner/admin write
    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.createdBy.uid == request.auth.uid || isAdmin()
      );
    }
    
    // Artists - public read, admin write
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User's liked songs subcollection
    match /users/{userId}/likedSongs/{songId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    match /users/{userId}/likedSongs:v1/{songId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // User's push notifications tokens subcollection
    match /users/{userId}/pushTokens/{tokenId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Promotions - public read, admin write
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Home app configuration - public read, admin write
    match /appConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // All other collections - admin only
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
